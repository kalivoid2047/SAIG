{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "saig-api",
      "runtimeExecutable": "apps/api/.venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "saig.main:app", "--port", "8000", "--app-dir", "apps/api"],
      "port": 8000
    },
    {
      "name": "saig-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "apps/web"],
      "port": 5173
    }
  ]
}
