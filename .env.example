# --- SAIG API (apps/api reads this via environment or apps/api/.env) ---

# Environment: development | test | staging | production
APP_ENV=development

# Database. Leave unset for a local SQLite dev file (Phase 0 modules only).
# Postgres (Supabase) example:
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres
#DATABASE_URL=

# JWT signing secret (HS256). MUST be set to a long random value outside development;
# the API refuses to boot in staging/production with the dev default.
#JWT_SECRET=

# Access/refresh token lifetimes
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7

# Comma-separated allowed CORS origins (the Vite dev server by default)
CORS_ORIGINS=http://localhost:5173

# Set true when serving over HTTPS (marks the refresh cookie Secure)
COOKIE_SECURE=false
